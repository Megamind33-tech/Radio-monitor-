// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Default to sqlite for easy setup in this env
  url      = env("DATABASE_URL")
}

model Station {
  id                         String   @id @default(cuid())
  name                       String
  country                    String
  /// City / district (e.g. Lusaka, Ndola, Luanshya)
  district                   String   @default("")
  /// Zambia province (e.g. Copperbelt, Lusaka, Southern)
  province                   String   @default("")
  /// FM frequency if parsed from station name (e.g. "94.5"); not always available from stream metadata
  frequencyMhz               String?
  streamUrl                  String
  /// When set, monitoring uses this URL instead of streamUrl (manual override / promoted direct source)
  preferredStreamUrl         String?
  streamFormatHint           String?
  /// radio_garden channel id, tunein station id, etc. (JSON string)
  sourceIdsJson              String?
  /// Last harvest result: good | partial | weak | none | error
  icyQualification           String?
  /// Truncated ICY StreamTitle sample from harvest
  icySampleTitle             String?
  isActive                   Boolean  @default(true)
  metadataPriorityEnabled    Boolean  @default(true)
  fingerprintFallbackEnabled Boolean  @default(true)
  metadataStaleSeconds       Int      @default(180)
  sampleSeconds              Int      @default(20)
  pollIntervalSeconds        Int      @default(60)
  /// Minimum seconds between audio fingerprint samples (scheduled), even when ICY unchanged
  audioFingerprintIntervalSeconds Int @default(300)
  /// Last time we captured audio for Chromaprint/AcoustID (scheduled or ICY-change path)
  lastAudioFingerprintAt     DateTime?
  /// First play of each distinct song only: ~30s WAV under SONG_SAMPLE_ARCHIVE_DIR (no duplicate file per repeat play)
  archiveSongSamples         Boolean  @default(true)
  /// Last monitor poll attempt (success or failure) for dashboard uptime
  lastPollAt                 DateTime?
  /// ok | error - set after each poll attempt
  lastPollStatus             String?
  /// Short error message when lastPollStatus is error
  lastPollError              String?
  /// ACTIVE_MUSIC | ACTIVE_NO_MATCH | ACTIVE_TALK | DEGRADED | INACTIVE | UNKNOWN
  monitorState               String   @default("UNKNOWN")
  /// Human readable reason code for current monitorState
  monitorStateReason         String?
  /// music | talk | ads | unknown_speech | mixed | unknown - content window (not stream online)
  contentClassification      String   @default("unknown")
  /// Last time stream health was validated (light or deep check)
  lastValidationAt           DateTime?
  /// Last validation failure or degrade reason
  lastValidationReason       String?
  /// Last final URL after redirect/playlist resolution
  lastResolvedStreamUrl      String?
  /// Last observed content-type header (audio/*, application/vnd.apple.mpegurl, etc.)
  lastStreamContentType      String?
  /// Last decoded audio codec from deep validation
  lastStreamCodec            String?
  /// Last decoded bitrate from deep validation
  lastStreamBitrate          Int?
  /// Last known healthy stream heartbeat (reachable/refreshing)
  lastHealthyAt              DateTime?
  /// Last known successful decoded audio frames
  lastGoodAudioAt            DateTime?
  /// Last time metadata endpoint provided a value
  lastMetadataAt             DateTime?
  /// Last time a confirmed song match was detected
  lastSongDetectedAt         DateTime?
  /// Failure counter for health checks (used for threshold-based INACTIVE transitions)
  consecutivePollFailures    Int      @default(0)
  /// Healthy counter for recovery threshold handling
  consecutiveHealthyPolls    Int      @default(0)
  /// Deep validation cadence (seconds)
  deepValidationIntervalSeconds Int   @default(600)
  /// Consecutive failure threshold before INACTIVE state
  failureThreshold           Int      @default(3)
  /// Consecutive healthy threshold to recover from INACTIVE
  recoveryThreshold          Int      @default(2)
  /// Visibility control in dashboards/admin
  visibilityEnabled          Boolean  @default(true)
  /// Running average detection lag (ms) between stream updates and recognized songs
  detectionLagMsAvg          Int?
  /// Number of lag samples used for detectionLagMsAvg
  detectionLagSamples        Int      @default(0)
  /// When streamUrl was auto-updated from sourceIdsJson (MyTuner / ORB / Streema)
  streamRefreshedAt          DateTime?
  /// direct | official_cdn | relay | aggregator | unknown (heuristic from URL)
  streamSourceType           String   @default("unknown")
  /// 0-100; higher = more trusted for fingerprint/metadata
  streamSourceQualityScore   Int      @default(50)
  streamSourceLastEvaluatedAt DateTime?
  /// EMA 0-1 decode success (ffprobe); does not affect stream online
  decodeHealthEma            Float    @default(1)
  /// EMA 0-1 fingerprint hit when attempted
  fingerprintHitEma        Float    @default(0)
  /// EMA 0-1 non-blank ICY when polled
  metadataPresentEma       Float    @default(0)
  /// Last poll: transport layer (SQLite 0/1)
  streamOnlineLast         Int      @default(0)
  audioDetectedLast        Int      @default(0)
  metadataAvailableLast    Int      @default(0)
  songIdentifiedLast       Int      @default(0)
  /// 0=default ICY trust; 1=stricter branding filter; 2=stricter callsign-like filter
  metadataTrustTightness     Int      @default(0)
  /// Chromaprint capture attempts when first sample yields no match (1-4)
  fingerprintRetries         Int      @default(2)
  /// Delay before each retry sample (ms), staggered window
  fingerprintRetryDelayMs    Int      @default(3500)
  /// When set, catalog hits below this confidence are ignored for merge (null = accept catalog as returned)
  catalogConfidenceFloor     Float?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  logs              DetectionLog[]
  currentNowPlaying CurrentNowPlaying?
  songSamples       SongSampleArchive[]
  songSpins         StationSongSpin[]
  streamEndpoints   StationStreamEndpoint[]
  healthEvents      StationHealthEvent[]
}

model StationStreamEndpoint {
  id                  String   @id @default(cuid())
  stationId           String
  source              String
  /// Source-specific identifier/url used for discovery
  sourceDetail        String?
  streamUrl           String
  resolvedUrl         String?
  isCurrent           Boolean  @default(false)
  isSuppressed        Boolean  @default(false)
  /// direct | official_cdn | relay | aggregator | unknown
  sourceTier          String   @default("unknown")
  /// 0-100 heuristic rank for source preference
  qualityScore        Int      @default(50)
  fingerprintHits     Int      @default(0)
  fingerprintAttempts Int      @default(0)
  decodeHits          Int      @default(0)
  decodeAttempts      Int      @default(0)
  metadataFreshHits   Int      @default(0)
  metadataPolls       Int      @default(0)
  lastValidatedAt     DateTime?
  /// healthy | degraded | inactive | unknown
  lastValidationStatus String?
  lastFailureReason   String?
  lastHealthyAt       DateTime?
  consecutiveFailures Int      @default(0)
  codec               String?
  bitrate             Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, streamUrl])
  @@index([stationId, isCurrent])
}

model StationHealthEvent {
  id                   String   @id @default(cuid())
  stationId            String
  observedAt           DateTime @default(now())
  monitorState         String
  reason               String?
  reachable            Boolean
  audioFlowing         Boolean
  decoderOk            Boolean
  contentClassification String
  resolvedUrl          String?
  contentTypeHeader    String?
  codec                String?
  bitrate              Int?
  latencyMs            Int?
  consecutiveFailures  Int

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([stationId, observedAt])
}

model DetectionLog {
  id              String   @id @default(cuid())
  stationId       String
  observedAt      DateTime @default(now())
  detectionMethod String   // stream_metadata, fingerprint_acoustid, catalog_lookup, unresolved
  rawStreamText   String?
  parsedArtist    String?
  parsedTitle     String?
  confidence      Float?
  acoustidScore   Float?
  /// AcoustID track UUID (top-level result id from AcoustID API). Distinct from MBID.
  acoustidId      String?
  recordingMbid   String?
  titleFinal      String?
  artistFinal     String?
  releaseFinal    String?
  releaseDate     String?
  genreFinal      String?
  sourceProvider  String?
  isrcList        String?  // JSON string
  sampleSeconds   Int?
  processingMs    Int?
  /// Track length from MusicBrainz/iTunes catalog (ms) when resolved - used to avoid duplicate logs during one spin
  trackDurationMs Int?
  status          String   // matched, unresolved, ignored
  reasonCode      String?
  /// JSON: fingerprint attempts, metadata quality flags, merge hints (pipeline audit)
  matchDiagnosticsJson String?

  station Station @relation(fields: [stationId], references: [id])
  songSample SongSampleArchive?
}

/// Aggregated play counts per station + normalized song key (one row per song; increments on each new play)
model StationSongSpin {
  id        String   @id @default(cuid())
  stationId String
  artistNorm String @default("")
  titleNorm  String
  albumNorm  String @default("")
  /// Metadata split rule id used when raw stream metadata had mixed artist/title text.
  mixRuleApplied String?
  /// Confidence (0..1) for the metadata split result.
  mixSplitConfidence Float?
  /// Original raw combined metadata before split (for audit/search/filtering).
  originalCombinedRaw String?
  /// Latest display values (same spin key, updated each play)
  artistLast String @default("")
  titleLast  String @default("")
  albumLast  String @default("")
  playCount  Int     @default(0)
  firstPlayedAt DateTime
  lastPlayedAt  DateTime
  lastDetectionLogId String?

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, artistNorm, titleNorm, albumNorm])
}

/// Optional ~30s WAV per detection for future fingerprinting / dispute evidence
model SongSampleArchive {
  id             String   @id @default(cuid())
  detectionLogId String   @unique
  stationId      String
  filePath       String
  durationSec    Int      @default(30)
  chromaprint    String?
  createdAt      DateTime @default(now())

  station      Station       @relation(fields: [stationId], references: [id], onDelete: Cascade)
  detectionLog DetectionLog  @relation(fields: [detectionLogId], references: [id], onDelete: Cascade)
}

model CurrentNowPlaying {
  stationId String   @id
  title     String?
  artist    String?
  album     String?
  genre     String?
  sourceProvider String?
  streamText String?
  updatedAt DateTime @updatedAt
  
  station Station @relation(fields: [stationId], references: [id])
}

model UnresolvedSample {
  id               String   @id @default(cuid())
  stationId        String
  /// DetectionLog row associated with this unresolved capture (nullable for older rows).
  detectionLogId   String?  @unique
  filePath         String
  createdAt        DateTime @default(now())
  /// pending | recovered | no_match | error | skipped
  recoveryStatus   String   @default("pending")
  recoveryAttempts Int      @default(0)
  lastRecoveryAt   DateTime?
  recoveredAt      DateTime?
  lastRecoveryError String?

  @@index([stationId, recoveryStatus, createdAt])
}

model CacheEntry {
  key       String   @id // e.g. fingerprint_hash
  value     String   // JSON string
  expiresAt DateTime
  type      String   // fingerprint, metadata, enrichment
}

/// Self-learned Chromaprint fingerprint library.
/// Populated from successful AcoustID matches and from trusted ICY stream metadata
/// paired with a captured audio fingerprint, so repeat plays can be resolved locally
/// without hitting AcoustID or MusicBrainz.
model LocalFingerprint {
  id                 String   @id @default(cuid())
  /// Full Chromaprint fingerprint (base64 as emitted by fpcalc / ffmpeg chromaprint muxer).
  fingerprint        String
  /// SHA-1 of `fingerprint` for exact-duplicate dedupe / fast equality hit.
  fingerprintSha1    String   @unique
  /// First 48 chars of `fingerprint` - indexed coarse prefix used as a candidate filter
  /// before byte-level hamming comparison in memory.
  fingerprintPrefix  String
  durationSec        Int
  title              String?
  artist             String?
  releaseTitle       String?
  releaseDate        String?
  genre              String?
  /// AcoustID track UUID (top-level `results[*].id` from AcoustID lookup, when known).
  acoustidTrackId    String?
  /// MusicBrainz recording MBID from the original resolving lookup.
  recordingMbid      String?
  /// JSON array of ISRC codes (stringified for SQLite).
  isrcsJson          String?
  /// "acoustid" | "stream_metadata" | "manual" - what originally taught us this fingerprint.
  source             String
  confidence         Float    @default(0)
  timesMatched       Int      @default(0)
  firstLearnedAt     DateTime @default(now())
  lastMatchedAt      DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([fingerprintPrefix, durationSec])
  @@index([acoustidTrackId])
  @@index([artist, title])
}

model JobRun {
  id        String   @id @default(cuid())
  stationId String
  status    String   // success, failure
  error     String?
  durationMs Int
  startedAt DateTime @default(now())
}
