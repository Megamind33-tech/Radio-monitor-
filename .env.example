# ─────────────────────────────────────────────────────────────────────────────
# Radio Monitor – Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL: SQLite for local dev; swap to postgres:// for production.
DATABASE_URL="file:./dev.db"

# ─── Song Identification (critical for 90%+ match rate) ──────────────────────

# AcoustID fingerprint lookup API key (FREE).
# Register your app at https://acoustid.org/new-application (takes 1 minute).
# Without this key the system can only identify songs via ICY stream text.
# With it, unknown and stuck-ICY songs are fingerprinted every 5 minutes.
ACOUSTID_API_KEY=""

# AcoustID score required to accept a fingerprint result (0–1).
# 0.65 is the sweet spot: below this false positives appear; above 0.80
# misses real matches on short or slightly noisy captures.
ACOUSTID_MIN_SCORE="0.65"

# When BOTH a fingerprint result AND a catalog (MusicBrainz/iTunes) result
# exist, prefer the fingerprint when its score is at or above this threshold.
ACOUSTID_PREFER_MIN_SCORE="0.65"

# MusicBrainz user-agent (REQUIRED for catalog lookups).
# Format: "AppName/Version ( contact@email.com )"
MUSICBRAINZ_USER_AGENT="RadioMonitor/1.0 ( your-email@example.com )"

# ─── Audio Capture ───────────────────────────────────────────────────────────

# Seconds of audio to capture per fingerprint attempt.
# 120 s gives AcoustID its full working window and maximises accuracy.
# Reduce to 60 on CPU-constrained hosts; do NOT go below 30.
FINGERPRINT_SAMPLE_SECONDS="120"

# Extra seconds added on retry attempts (0 = no bonus; try 10–20 for tough streams)
FINGERPRINT_EXTRA_SAMPLE_SECONDS="0"

# Retries per fingerprint cycle (1–4). 2 is enough for most streams.
FINGERPRINT_MAX_RETRIES="2"

# Milliseconds between fingerprint retry attempts
FINGERPRINT_RETRY_DELAY_MS="3500"

# How many seconds between scheduled fingerprint captures even when ICY is unchanged
AUDIO_FINGERPRINT_INTERVAL_SECONDS="300"

# Set "true" to fingerprint on every poll — heavy on CPU/AcoustID quota; not recommended
FINGERPRINT_EVERY_POLL="false"

# Also fingerprint when ICY heuristics flag slogan/branding text (default false)
FINGERPRINT_AGGRESSIVE_ON_SUSPICIOUS_METADATA="false"

# ─── Sample Archive ───────────────────────────────────────────────────────────

# Where to store first-play WAV samples (for dispute evidence / manual re-ID)
SONG_SAMPLE_ARCHIVE_DIR="/workspace/data/song_samples"
ARCHIVE_SAMPLE_SECONDS="30"

# Archive unresolved clips so the Audio Editor can replay and manually tag them
ARCHIVE_UNRESOLVED_SAMPLES="true"
UNRESOLVED_SAMPLE_DIR="/workspace/data/unresolved_samples"
# Max unresolved clips kept per station (0 = keep all)
UNRESOLVED_SAMPLE_MAX_PER_STATION="0"

# ─── Duplicate-play Suppression ──────────────────────────────────────────────

# Maximum time (ms) the system will suppress duplicate detection logs for the
# same song.  Default 15 min (900000).  Increase for stations with long tracks.
TRACK_GUARD_MAX_MS="900000"

# Fallback guard duration (ms) when no catalog track length is available.
TRACK_GUARD_FALLBACK_MS="240000"

# ─── Catalog Confidence ───────────────────────────────────────────────────────

# Minimum confidence for MusicBrainz / iTunes / Deezer text-catalog results
CATALOG_LOOKUP_MIN_SCORE="0.65"

# Deezer public search (no API key required). Set "false" to disable.
DEEZER_LOOKUP_ENABLED="true"

# ─── Stream Discovery ─────────────────────────────────────────────────────────

# Auto-promote preferredStreamUrl when a better-tier endpoint is found
AUTO_PROMOTE_DIRECT_STREAM_URL="true"

# Radio-Browser API mirror list (space or comma separated)
# RADIO_BROWSER_API_BASES="https://de1.api.radio-browser.info https://all.api.radio-browser.info"
# STREAM_DISCOVERY_UA="RadioMonitor/1.0 (contact@example.com)"

# ─── Polling / Scheduling ─────────────────────────────────────────────────────

MAX_STATION_CONCURRENCY="5"
DEFAULT_SAMPLE_SECONDS="20"
DEFAULT_POLL_INTERVAL_SECONDS="60"

# ─── Metadata Staleness ───────────────────────────────────────────────────────

# How many seconds of unchanged ICY text before the system considers metadata
# stale and triggers a fingerprint verification attempt.  Default 180 s (3 min).
# METADATA_STALE_SECONDS="180"

# ─── Unresolved Sample Recovery ───────────────────────────────────────────────

# Max AcoustID retry attempts per unresolved clip before giving up (lifetime total).
# Once this is reached the clip is permanently marked no_match.
UNRESOLVED_RECOVERY_MAX_ATTEMPTS="24"

# Days to wait before re-queuing a no_match clip for another AcoustID attempt.
UNRESOLVED_RECOVERY_NO_MATCH_COOLDOWN_DAYS="7"

# Clips per scheduled recovery batch (runs every 2 minutes)
UNRESOLVED_RECOVERY_BATCH_SIZE="50"

# ─── Application ──────────────────────────────────────────────────────────────

APP_ENV="development"
LOG_LEVEL="info"

# Temporary directory for in-progress audio captures (cleaned up automatically)
TEMP_AUDIO_DIR="/tmp/radio_monitor"
