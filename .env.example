# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL or SQLite connection string.
# Defaulting to sqlite for local dev in this environment.
DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────────────────────────────────────
# AUDIO IDENTIFICATION (the order below is the priority order)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Local fingerprint library (free, self-learned)            — always on
# 2. AcoustID (free)                                           — needs ACOUSTID_API_KEY
# 3. AudD (paid)                                               — needs AUDD_API_TOKEN
# 4. ACRCloud (paid)                                           — needs 3 ACRCLOUD_* vars
# 5. MusicBrainz / iTunes / Deezer text catalog lookup          — free, always on
# ─────────────────────────────────────────────────────────────────────────────

# ACOUSTID_API_KEY: Get one (free) at https://acoustid.org/applications
ACOUSTID_API_KEY=""
# AcoustID minimum normalized score to accept a match (0..1). Lower = more recall, more risk of wrong IDs.
ACOUSTID_MIN_SCORE="0.55"
# Prefer AcoustID over text catalog when this score clears (0..1)
ACOUSTID_PREFER_MIN_SCORE="0.55"
# When AcoustID disagrees with catalog text, require this minimum AcoustID score to override catalog
ACOUSTID_MIN_SCORE_OVER_CATALOG="0.62"

# AudD recognition fallback — used after AcoustID miss when we have a sample.
# Sign up token at https://dashboard.audd.io/
AUDD_API_TOKEN=""
# AUDD_ALLOW_TOKENLESS="false"
AUDD_MIN_SCORE="0.55"

# ACRCloud Identify (paid). Host comes from the console e.g. identify-eu-west-1.acrcloud.com
ACRCLOUD_HOST=""
ACRCLOUD_ACCESS_KEY=""
ACRCLOUD_ACCESS_SECRET=""
ACRCLOUD_DATA_TYPE="audio"
ACRCLOUD_MIN_SCORE="55"

# When false, never calls AudD/ACRCloud (AcoustID + free catalog only for audio).
PAID_AUDIO_FALLBACKS_ENABLED="true"
# When true (default), try AudD/ACR after any AcoustID miss when we have a sample
# (not only suspicious ICY) — this materially improves match rate.
PAID_ON_AUDIO_MISS="true"

# ─────────────────────────────────────────────────────────────────────────────
# MATCH HONESTY — the most important switch in this file
# ─────────────────────────────────────────────────────────────────────────────
# When true, "trusted" ICY text (Artist – Title) can count as matched even without
# a catalog or fingerprint confirmation. We DEFAULT this to FALSE so unknown ICY
# (station IDs, branding, talk text) is never falsely reported as a played song.
# Combined with the catalog text-lookup chain (MusicBrainz / iTunes / Deezer)
# this typically RAISES real match rate while removing fake matches.
ALLOW_STREAM_METADATA_MATCH_WITHOUT_ID="false"

# Background catalog repair: re-query MB/iTunes/Deezer for recent unresolved logs with raw ICY
CATALOG_REPAIR_ENABLED="true"
CATALOG_REPAIR_BATCH_LIMIT="50"

# Catalog fallback threshold for public search APIs (MusicBrainz/iTunes/Deezer).
CATALOG_LOOKUP_MIN_SCORE="0.62"
# Deezer public search (no API key). Set to "false" to disable third chain.
DEEZER_LOOKUP_ENABLED="true"

# ─────────────────────────────────────────────────────────────────────────────
# FINGERPRINT PIPELINE
# ─────────────────────────────────────────────────────────────────────────────
# Fingerprint pipeline: spacing between capture starts (ms) and max concurrent captures —
# tune so many stations do not stack on AcoustID rate limits.
FINGERPRINT_PIPELINE_MIN_GAP_MS="750"
FINGERPRINT_PIPELINE_MAX_CONCURRENT="2"

# Sample length (seconds): AcoustID looks at the first 120s of audio. Longer samples
# materially improve identification on songs with quiet intros / fade-ins.
FINGERPRINT_SAMPLE_SECONDS="60"
DEFAULT_SAMPLE_SECONDS="60"
# Extra seconds added on retry attempts (capped at 25 s)
FINGERPRINT_EXTRA_SAMPLE_SECONDS="15"

# Re-fingerprint every poll (heavy). Default false; turn on per-station for stations with bad ICY.
FINGERPRINT_EVERY_POLL="false"
# Also fingerprint when ICY exists but heuristics flag slogan/program (default true: more recall)
FINGERPRINT_AGGRESSIVE_ON_SUSPICIOUS_METADATA="true"

# Staggered retry: max attempts (1-4) and delay ms between attempts (per-station overrides in DB)
FINGERPRINT_MAX_RETRIES="3"
FINGERPRINT_RETRY_DELAY_MS="5000"

# Force high-frequency retries for unresolved samples until recovery succeeds
UNRESOLVED_FORCE_RETRY="true"
UNRESOLVED_RECOVERY_MAX_ATTEMPTS="1000000"
UNRESOLVED_RECOVERY_NO_MATCH_COOLDOWN_DAYS="0"

# Local library must be at least this confident to skip AcoustID (default 0.88)
LOCAL_FP_MIN_CONFIDENCE_FOR_SKIP_ACOUSTID="0.88"
# Local library minimum prefix similarity (default 0.80) — lower for more recall on noisy streams
LOCAL_FP_MIN_SIMILARITY="0.78"
LOCAL_FP_MAX_BER="0.35"
LOCAL_FP_DURATION_TOLERANCE_SEC="30"
LOCAL_FP_LEARNING_ENABLED="true"

# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVE & EVIDENCE
# ─────────────────────────────────────────────────────────────────────────────
# First play of each distinct song only (~30s WAV), not every repeat spin
SONG_SAMPLE_ARCHIVE_DIR="/opt/mostify/data/song_samples"
ARCHIVE_SAMPLE_SECONDS="30"
ARCHIVE_UNRESOLVED_SAMPLES="true"
UNRESOLVED_SAMPLE_DIR="/opt/mostify/data/unresolved_samples"
UNRESOLVED_SAMPLE_MAX_PER_STATION="50"

# Duplicate suppression for same ICY title: max guard (ms) and fallback when catalog length unknown
TRACK_GUARD_MAX_MS="900000"
TRACK_GUARD_FALLBACK_MS="240000"
# ICY-only "match" can hide wrong stuck text; allow a new log sooner than the full MB duration.
TRACK_GUARD_STREAM_METADATA_MAX_MS="360000"

# When current mount is relay/aggregator, auto-set preferredStreamUrl from a better
# StationStreamEndpoint row if found.
AUTO_PROMOTE_DIRECT_STREAM_URL="true"

# ─────────────────────────────────────────────────────────────────────────────
# STREAM DISCOVERY
# ─────────────────────────────────────────────────────────────────────────────
# Multi-server stream discovery: comma/space-separated radio-browser API bases.
RADIO_BROWSER_API_BASES="https://de1.api.radio-browser.info https://de2.api.radio-browser.info https://fi1.api.radio-browser.info https://nl1.api.radio-browser.info https://all.api.radio-browser.info"
STREAM_DISCOVERY_UA="MOSTIFY/1.0 (contact@example.com)"

# MUSICBRAINZ_USER_AGENT: Required - format "AppName/Version ( contact@email )"
# per https://musicbrainz.org/doc/MusicBrainz_API/Rate_Limiting
MUSICBRAINZ_USER_AGENT="MOSTIFY/1.0.0 ( chansamax198@gmail.com )"

# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV="development"
LOG_LEVEL="info"
TEMP_AUDIO_DIR="/tmp/radio_monitor"

# Parallel station polls (higher = fewer "deferred" ticks when many stations)
MAX_STATION_CONCURRENCY="8"
DEFAULT_POLL_INTERVAL_SECONDS="60"
