# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL or SQLite connection string.
# Defaulting to sqlite for local dev in this environment.
DATABASE_URL="file:./dev.db"

# ACOUSTID_API_KEY: Get one at https://acoustid.org/applications
ACOUSTID_API_KEY=""

# MUSICBRAINZ_USER_AGENT: Required - format "AppName/Version ( contact@email )" per https://musicbrainz.org/doc/MusicBrainz_API/Rate_Limiting
MUSICBRAINZ_USER_AGENT="MOSTIFY/1.0.0 ( chansamax198@gmail.com )"

# APP_ENV: development or production
APP_ENV="development"

# LOG_LEVEL: debug, info, warn, error
LOG_LEVEL="info"

# TEMP_AUDIO_DIR: Path to store temporary audio clips
TEMP_AUDIO_DIR="/tmp/radio_monitor"

# Optional: first play of each distinct song only (~30s WAV), not every repeat spin
# SONG_SAMPLE_ARCHIVE_DIR="/workspace/data/song_samples"
# ARCHIVE_SAMPLE_SECONDS="30"
# ARCHIVE_UNRESOLVED_SAMPLES="true"
# UNRESOLVED_SAMPLE_DIR="/workspace/data/unresolved_samples"
# UNRESOLVED_SAMPLE_MAX_PER_STATION="0"   # 0 disables pruning; keep all unresolved samples

# Duplicate suppression for same ICY title: max guard (ms) and fallback when catalog length unknown
# TRACK_GUARD_MAX_MS="900000"
# TRACK_GUARD_FALLBACK_MS="240000"

# Audio ID: prefer AcoustID over text catalog when score >= this (0-1)
# ACOUSTID_PREFER_MIN_SCORE="0.55"
# Extra seconds for fingerprint capture (min sampleSeconds)
# FINGERPRINT_SAMPLE_SECONDS="25"

# Configuration Defaults
MAX_STATION_CONCURRENCY="5"
DEFAULT_SAMPLE_SECONDS="20"
DEFAULT_POLL_INTERVAL_SECONDS="60"
ACOUSTID_MIN_SCORE="0.5"

# Catalog fallback threshold for public search APIs (MusicBrainz/iTunes/Deezer).
CATALOG_LOOKUP_MIN_SCORE="0.65"

# Deezer public search (no API key). Set to "false" to disable third chain.
DEEZER_LOOKUP_ENABLED="true"
