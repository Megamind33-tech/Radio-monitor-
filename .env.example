# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL or SQLite connection string.
# Prefer `file:./prisma/dev.db` so the path is stable (root `./dev.db` is easy to confuse with an empty file).
DATABASE_URL="file:./prisma/dev.db"

# Empty Station table on server start: load real Zambia streams (ZNBC + Radio Browser country ZM).
# Set "false" in production if you only use harvest/import. Set "true" to allow bootstrap in production.
# AUTO_ZAMBIA_CATALOG_BOOTSTRAP="true"
# ZAMBIA_BOOTSTRAP_MAX_STATIONS="48"

# ACOUSTID_API_KEY: Get one at https://acoustid.org/applications
ACOUSTID_API_KEY=""

# AudD recognition fallback — only after AcoustID miss when ICY looks non-song / untrusted (see PAID_AUDIO_FALLBACKS_ENABLED)
# Sign up token at https://dashboard.audd.io/
AUDD_API_TOKEN=""
# Allow tokenless requests for smoke tests only (not recommended in production)
# AUDD_ALLOW_TOKENLESS="false"
# Minimum normalized confidence (0..1) to accept AudD matches
# AUDD_MIN_SCORE="0.55"
# ACRCloud Identify (optional paid fallback after AudD when ICY is suspicious). Host from console e.g. identify-eu-west-1.acrcloud.com
# ACRCLOUD_HOST="identify-eu-west-1.acrcloud.com"
# ACRCLOUD_ACCESS_KEY=""
# ACRCLOUD_ACCESS_SECRET=""
# ACRCLOUD_DATA_TYPE="audio"
# ACRCLOUD_MIN_SCORE="55"
# When false, never calls AudD/ACRCloud (AcoustID + free catalog only for audio)
# PAID_AUDIO_FALLBACKS_ENABLED="true"
# When true (default), try AudD/ACR after any AcoustID miss when we have a sample (not only suspicious ICY)
# PAID_ON_AUDIO_MISS="true"

# Background catalog repair: re-query MB/iTunes/Deezer for recent unresolved logs with raw ICY
# CATALOG_REPAIR_ENABLED="true"
# CATALOG_REPAIR_BATCH_LIMIT="25"

# Fingerprint pipeline: spacing between capture starts (ms) and max concurrent captures — tune so many stations do not stack on AcoustID
# FINGERPRINT_PIPELINE_MIN_GAP_MS="750"
# FINGERPRINT_PIPELINE_MAX_CONCURRENT="2"

# MUSICBRAINZ_USER_AGENT: Required - format "AppName/Version ( contact@email )" per https://musicbrainz.org/doc/MusicBrainz_API/Rate_Limiting
MUSICBRAINZ_USER_AGENT="MOSTIFY/1.0.0 ( chansamax198@gmail.com )"

# APP_ENV: development or production
APP_ENV="development"

# LOG_LEVEL: debug, info, warn, error
LOG_LEVEL="info"

# TEMP_AUDIO_DIR: Path to store temporary audio clips
TEMP_AUDIO_DIR="/tmp/radio_monitor"

# Optional: first play of each distinct song only (~30s WAV), not every repeat spin
# SONG_SAMPLE_ARCHIVE_DIR="/workspace/data/song_samples"
# ARCHIVE_SAMPLE_SECONDS="30"
# ARCHIVE_UNRESOLVED_SAMPLES="true"
# UNRESOLVED_SAMPLE_DIR="/workspace/data/unresolved_samples"
# UNRESOLVED_SAMPLE_MAX_PER_STATION="0"   # 0 disables pruning; keep all unresolved samples

# Duplicate suppression for same ICY title: max guard (ms) and fallback when catalog length unknown
# TRACK_GUARD_MAX_MS="900000"
# TRACK_GUARD_FALLBACK_MS="240000"

# Audio ID: prefer AcoustID over text catalog when score >= this (0-1)
# ACOUSTID_PREFER_MIN_SCORE="0.55"
# Extra seconds for fingerprint capture (min sampleSeconds)
# FINGERPRINT_SAMPLE_SECONDS="25"
# Extra seconds added on fingerprint retry attempts (capped)
# FINGERPRINT_EXTRA_SAMPLE_SECONDS="0"
# When true, fingerprint on every poll (heavy). When false, suspicious ICY still triggers audio via FINGERPRINT_AGGRESSIVE_ON_SUSPICIOUS_METADATA.
# FINGERPRINT_EVERY_POLL="false"
# Also fingerprint when ICY exists but heuristics flag slogan/program (default false for ICY stability)
# FINGERPRINT_AGGRESSIVE_ON_SUSPICIOUS_METADATA="false"
# When true (default), trusted ICY can count as matched like classic behavior. Set false to require catalog/fingerprint only.
# ALLOW_STREAM_METADATA_MATCH_WITHOUT_ID="true"
# Staggered retry: max attempts (1-4) and delay ms between attempts (per-station overrides in DB)
# FINGERPRINT_MAX_RETRIES="2"
# FINGERPRINT_RETRY_DELAY_MS="3500"
# Force high-frequency retries for unresolved samples until recovery succeeds
# UNRESOLVED_FORCE_RETRY="true"
# UNRESOLVED_RECOVERY_MAX_ATTEMPTS="1000000"
# UNRESOLVED_RECOVERY_NO_MATCH_COOLDOWN_DAYS="0"

# When current mount is relay/aggregator, auto-set preferredStreamUrl from a better StationStreamEndpoint row if found
# AUTO_PROMOTE_DIRECT_STREAM_URL="true"

# Multi-server stream discovery: comma/space-separated radio-browser API bases (default: de1,de2,fi1,nl1,all)
# RADIO_BROWSER_API_BASES="https://de1.api.radio-browser.info https://all.api.radio-browser.info"
# STREAM_DISCOVERY_UA="RadioMonitor/1.0 (contact@example.com)"

# Configuration Defaults
# Parallel station polls (higher = fewer "deferred" ticks when many stations; default 8)
MAX_STATION_CONCURRENCY="8"
DEFAULT_SAMPLE_SECONDS="20"
DEFAULT_POLL_INTERVAL_SECONDS="60"
ACOUSTID_MIN_SCORE="0.55"
# Local library must be at least this confident to skip AcoustID (default 0.88)
# LOCAL_FP_MIN_CONFIDENCE_FOR_SKIP_ACOUSTID="0.88"

# Catalog fallback threshold for public search APIs (MusicBrainz/iTunes/Deezer).
CATALOG_LOOKUP_MIN_SCORE="0.65"

# Deezer public search (no API key). Set to "false" to disable third chain.
DEEZER_LOOKUP_ENABLED="true"
