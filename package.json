{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx server/main.ts",
    "build": "vite build && tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server/main.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "harvest:zambia": "python3 scripts/zambia_station_harvest.py --max-probe 400 --out scripts/data/zambia_harvest.json",
    "import:zambia": "node scripts/import_zambia_stations.mjs scripts/data/zambia_harvest.json",
    "import:zambia:replace": "node scripts/import_zambia_stations.mjs --replace scripts/data/zambia_harvest.json",
    "audit:mytuner-zambia": "python3 scripts/mytuner_zambia_audit.py scripts/data/zambia_harvest.json scripts/data/mytuner_zambia_audit.csv",
    "poll:orb-tracks": "node scripts/orb_track_poller.mjs",
    "backfill:song-spins": "node scripts/backfill_station_song_spins.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "5.10.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^3.0.3",
    "pino": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "validator": "^13.11.0",
    "vite": "^6.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "pino-pretty": "^13.1.3",
    "prisma": "5.10.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
