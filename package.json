{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx server/main.ts",
    "build": "vite build && tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server/main.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "harvest:zambia": "python3 scripts/zambia_station_harvest.py --max-probe 800 --out scripts/data/zambia_harvest.json",
    "harvest:zambia:wide": "python3 scripts/zambia_station_harvest.py --max-probe 1400 --mytuner-pages 20 --out scripts/data/zambia_harvest.json",
    "harvest:zambia:with-no-icy": "python3 scripts/zambia_station_harvest.py --max-probe 1400 --mytuner-pages 20 --include-no-icy --out scripts/data/zambia_harvest.json",
    "import:zambia": "node scripts/import_zambia_stations.mjs scripts/data/zambia_harvest.json",
    "import:zambia:replace": "node scripts/import_zambia_stations.mjs --replace scripts/data/zambia_harvest.json",
    "import:zambia:replace-stations-only": "node scripts/import_zambia_stations.mjs --replace-stations-only scripts/data/zambia_harvest.json",
    "sync:zambia": "node scripts/sync_zambia_catalog.mjs",
    "audit:mytuner-zambia": "python3 scripts/mytuner_zambia_audit.py scripts/data/zambia_harvest.json scripts/data/mytuner_zambia_audit.csv",
    "poll:orb-tracks": "node scripts/orb_track_poller.mjs",
    "backfill:song-spins": "node scripts/backfill_station_song_spins.mjs",
    "audit:stream-health": "node scripts/stream_health_audit.mjs",
    "fetch:radiotime:zambia": "python3 scripts/radiotime_zambia_fetch.py --out scripts/data/radiotime_zambia.json",
    "harvest:radio-browser:zambia": "node scripts/zambia_radio_browser_harvest.mjs --import --validate",
    "validate:streams": "node scripts/strict_stream_validator.mjs --auto-fix",
    "validate:streams:dry": "node scripts/strict_stream_validator.mjs",
    "diagnose:match-rate": "node scripts/diagnose_match_rate.mjs",
    "optimize:stations": "node scripts/optimize_stations.mjs",
    "optimize:stations:apply": "node scripts/optimize_stations.mjs --apply",
    "drain:unresolved": "node scripts/drain_unresolved_aggressive.mjs --max-passes 10 --batch 30",
    "audit:unresolved-recovery": "tsx scripts/unresolved_recovery_dry_run.ts",
    "recover:unresolved-safe-title": "tsx scripts/unresolved_safe_title_recover.ts",
    "queue:unresolved-enrichment": "tsx scripts/unresolved_enqueue_enrichment.ts",
    "test:station-health": "tsx server/lib/station-health.spec.ts",
    "test:stream-url-guard": "tsx server/lib/stream-url-guard.spec.ts",
    "test:local-fingerprint": "tsx server/services/local-fingerprint.service.spec.ts",
    "test:audio-id-merge": "tsx server/lib/audio-id-merge.spec.ts",
    "test:unresolved-evidence": "tsx server/lib/unresolved-evidence.spec.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "5.10.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsdom": "^29.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^3.0.3",
    "pino": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "validator": "^13.11.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "pino-pretty": "^13.1.3",
    "prisma": "5.10.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
